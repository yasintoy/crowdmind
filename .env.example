# Crowdmind Configuration
# Copy this file to .env and fill in your values

# ===========================================
# LLM Provider (pick ONE, or multiple for fallback)
# ===========================================

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google - https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=...

# Groq (fastest, cheapest) - https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Expected Parrot (EDSL hosted) - https://expectedparrot.com
EXPECTED_PARROT_API_KEY=...

# ===========================================
# Optional Settings
# ===========================================

# Default model (provider-specific)
# Examples: gpt-4o, claude-sonnet-4-6, gemini-pro, llama-3-70b
CROWDMIND_MODEL=gpt-4o

# Default number of personas for validation
CROWDMIND_PERSONAS=10

# Cache directory
CROWDMIND_CACHE_DIR=~/.crowdmind/cache
